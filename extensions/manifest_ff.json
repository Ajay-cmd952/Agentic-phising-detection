
{
  "manifest_version": 3,
  "name": "Agentic Phishing Shield",
  "version": "1.1",
  "description": "Real-time AI phishing detection and neural download protection.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "tabs",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://ajay0006-agentic-shield-api.hf.space/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["jsQR.js", "content.js"] 
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "agentic-shield@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}